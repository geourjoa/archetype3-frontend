# Environment variables for docker-compose development mode.

COMPOSE_FILE=compose.yml:dev.yml

FRONT_END_PORT=3000

# Public API base URL (no trailing slash). Used for data and media.
NEXT_PUBLIC_API_URL=http://api

# IIIF image server (Sipi) base URL. Used for image proxy rewrites.
NEXT_PUBLIC_IIIF_UPSTREAM=http://image_server:1024

# Canonical site URL for metadata, sitemap, and robots.
NEXT_PUBLIC_SITE_URL=https://archetype.gla.ac.uk

# Comma-separated origins allowed for CORS on /api/* routes.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://api

DOCKER_IMAGE_HASH=3

RESTART=no
